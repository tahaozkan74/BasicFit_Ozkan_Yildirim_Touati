<Window x:Class="SAE_2._01_Basic_Fit.Employe.Window.popupDetailCours"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SAE_2._01_Basic_Fit.Employe.Window"
        mc:Ignorable="d"
        Title="popupDetailCours" Height="550" Width="600">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="txtTitre" Grid.Row="0"
                   Text="Cardio Blast - 08:00"
                   FontSize="20" FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal" Margin="0,3">
                <TextBlock Text="Catégorie : " FontWeight="Bold"/>
                <TextBlock x:Name="txtCategorie" Text="" Width="402"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,3">
                <TextBlock Text="Description : " FontWeight="Bold"/>
                <TextBlock x:Name="txtDescription" 
                           Text=""
                           TextWrapping="Wrap" MaxWidth="450" Width="410"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,3">
                <TextBlock Text="Salle : " FontWeight="Bold"/>
                <TextBlock x:Name="txtSalle" Text="" Width="201"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,3">
                <TextBlock Text="Entraîneur : " FontWeight="Bold"/>
                <TextBlock x:Name="txtEntraineur" Text="" RenderTransformOrigin="0.5,0.5" Width="158">
                    <TextBlock.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform/>
                            <SkewTransform/>
                            <RotateTransform Angle="0.126"/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </TextBlock.RenderTransform>
                </TextBlock>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,3">
                <TextBlock Text="Places : " FontWeight="Bold"/>
                <TextBlock x:Name="txtPlaces" Text="" Background="White" Width="91"/>
            </StackPanel>
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="txtNbParticipants"
                       Grid.Row="0"
                       Text="👥 Participants (3)"
                       FontWeight="Bold" FontSize="14"
                       Margin="0,5,0,10"/>

            <DataGrid x:Name="dgParticipants" Grid.Row="1"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      Background="White"
                      RowBackground="White"
                      AlternatingRowBackground="#FFF7F7F7">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="*"/>
                    <DataGridTextColumn Header="Prénom" Binding="{Binding Prenom}" Width="*"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Mail}" Width="2*"/>
                    <DataGridTextColumn Header="Téléphone" Binding="{Binding Telephone}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="butFermer" Content="Fermer"
                    Width="110" Height="38"
                    Background="#FFE5E5E5" BorderBrush="#FFE5E5E5"
                    FontSize="14"
                    Click="butFermer_Click"/>
        </StackPanel>
    </Grid>
</Window>
