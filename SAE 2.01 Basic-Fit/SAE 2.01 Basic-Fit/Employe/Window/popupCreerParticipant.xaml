<Window x:Class="SAE_2._01_Basic_Fit.Employe.Window.popupCreerParticipant"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SAE_2._01_Basic_Fit.Employe.Window"
        mc:Ignorable="d"
        Title="popupCreerParticipant" Height="550" Width="650">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="+ Créer un nouveau participant"
                   FontSize="20" FontWeight="Bold"
                   Margin="0,0,0,25"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="15"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="15"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="15"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Nom *" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBlock Grid.Row="0" Grid.Column="2" Text="Prénom *" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtNom" Grid.Row="1" Grid.Column="0" Height="28" Padding="3"/>
            <TextBox x:Name="txtPrenom" Grid.Row="1" Grid.Column="2" Height="28" Padding="3"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Email *" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBlock Grid.Row="3" Grid.Column="2" Text="Téléphone *" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtEmail" Grid.Row="4" Grid.Column="0" Height="28" Padding="3"/>
            <TextBox x:Name="txtTelephone" Grid.Row="4" Grid.Column="2" Height="28" Padding="3"/>

            <TextBlock Grid.Row="6" Grid.Column="0" Text="Date de naissance *" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBlock Grid.Row="6" Grid.Column="2" Text="Adresse *" FontWeight="Bold" Margin="0,0,0,5"/>
            <DatePicker x:Name="dpDateNaissance" Grid.Row="7" Grid.Column="0" Height="28"/>
            <TextBox x:Name="txtAdresse" Grid.Row="7" Grid.Column="2" Height="28" Padding="3"/>

            <TextBlock Grid.Row="9" Grid.Column="0" Text="Code postal *" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBlock Grid.Row="9" Grid.Column="2" Text="Ville *" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtCodePostal" Grid.Row="10" Grid.Column="0" Height="28" Padding="3"/>
            <TextBox x:Name="txtVille" Grid.Row="10" Grid.Column="2" Height="28" Padding="3"/>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,0">
            <Button x:Name="butAnnuler" Content="Annuler"
                    Width="110" Height="38"
                    Background="#FFE5E5E5" BorderBrush="#FFE5E5E5"
                    FontSize="14" Margin="0,0,10,0"
                    Click="butAnnuler_Click"/>
            <Button x:Name="butCreer" Content="✓ Créer"
                    Width="130" Height="38"
                    Background="#FF4CAF50" BorderBrush="#FF4CAF50" Foreground="White"
                    FontSize="14" FontWeight="Bold"
                    Click="butCreer_Click"/>
        </StackPanel>
    </Grid>
</Window>
