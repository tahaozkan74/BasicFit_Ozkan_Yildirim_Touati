<UserControl x:Class="SAE_2._01_Basic_Fit.Employe.UCWindow.pagePrincipal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SAE_2._01_Basic_Fit.Employe.UCWindow"
             mc:Ignorable="d" 
             d:DesignHeight="750" d:DesignWidth="1250">
    <Grid Background="#FFFF8C42">
        <StackPanel>
            <Border BorderThickness="1" Height="250" Background="White" Margin="-5,-5,-5,0">

                <StackPanel Orientation="Horizontal" Margin="0,0,0,100">
                    <Image Source="/Image/basic-fit-logo.png" Height="99" Width="302" Margin="23,-15,0,0" />
                    <TextBlock Text="ESPACE EMPLOYE" FontSize="50" FontWeight="Bold" Foreground="Black" Width="416" Height="70" Margin="108,-15,0,0"/>
                    <Border BorderThickness="1" Height="52" Width="221" Background="#FFA7A6A6" CornerRadius="20,20,20,20" Margin="56,-15,0,0"/>
                    <Button Width="50" Height="50" Margin="20,-15,0,0" Background="White" BorderBrush="White">
                        <Image Source="/Image/logout.png" Height="45" Width="97" RenderTransformOrigin="0.5,0.5" Margin="-17,0,0,0">
                            <Image.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform/>
                                    <SkewTransform AngleY="-0.39"/>
                                    <RotateTransform/>
                                    <TranslateTransform Y="-0.16"/>
                                </TransformGroup>
                            </Image.RenderTransform>
                        </Image>
                    </Button>
                </StackPanel>

            </Border>

        </StackPanel>
    </Grid>
</UserControl>
