<UserControl x:Class="SAE_2._01_Basic_Fit.Employe.UCWindow.pagePrincipal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SAE_2._01_Basic_Fit.Employe.UCWindow"
             mc:Ignorable="d" 
             d:DesignHeight="750" d:DesignWidth="1250">
    <Grid Background="#FFFF8C42">
        <StackPanel>
            <Border BorderThickness="1" Height="215" Margin="-1,-1,-1,0" Background="White">

                <StackPanel Orientation="Horizontal" Margin="0,0,0,-1">
                    <Image Source="/Image/basic-fit-logo.png" Height="99" Width="302" Margin="23,-15,0,97" />
                    <TextBlock Text="ESPACE EMPLOYE" FontSize="50" FontWeight="Bold" Foreground="Black" Width="416" Height="70" Margin="108,-15,0,100"/>
                    <Border BorderThickness="1" Height="52" Width="221" Background="#FFA7A6A6" CornerRadius="20,20,20,20" Margin="56,-15,0,100"/>
                    <Button Width="50" Height="50" Margin="20,-15,0,100" Background="White" BorderBrush="White">
                        <Image Source="/Image/logout.png" Height="45" Width="97" RenderTransformOrigin="0.5,0.5" Margin="-17,0,0,0">
                            <Image.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform/>
                                    <SkewTransform AngleY="-0.39"/>
                                    <RotateTransform/>
                                    <TranslateTransform Y="-0.16"/>
                                </TransformGroup>
                            </Image.RenderTransform>
                        </Image>
                    </Button>
                    <Button x:Name="butCoursJour" Content="📅 Cours du jour " FontSize="30" FontWeight="Bold" Foreground="Black" Width="248" Height="56" Margin="-2096,145,0,0" Background="White" BorderBrush="White" Click="butCoursJour_Click" />
                    <Button Content="🔎 Recherche cours" FontSize="30" FontWeight="Bold" Foreground="Black" Width="292" Height="56" Margin="-1504,145,0,0" BorderBrush="White" Background="White" />
                    <Button Content="Participant" FontSize="30" FontWeight="Bold" Foreground="Black" Width="198" Height="56" Margin="-950,145,0,0" BorderBrush="White" Background="White" />
                </StackPanel>
            </Border>

        </StackPanel>

        <ScrollViewer Margin="0,212,0,0">
            <ContentControl x:Name="ZoneContenu" Margin="0,-35,0,0" Height="483"/>
        </ScrollViewer> 
    </Grid>
</UserControl>
