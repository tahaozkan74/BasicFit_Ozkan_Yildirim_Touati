<UserControl x:Class="SAE_2._01_Basic_Fit.Employe.UCWindow.pageCours"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SAE_2._01_Basic_Fit.Employe.UCWindow"
             mc:Ignorable="d" 
             d:DesignHeight="750" d:DesignWidth="1250">
    <Grid>
        <Border Background="#FFFF8C42">
            <Border BorderThickness="1" Margin="50,34,50,32" Width="1150" Background="White" CornerRadius="10,10,10,10">
                <DataGrid x:Name="dgCours"
                  ItemsSource="{Binding Seance}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#FFEEEEEE"
                  BorderThickness="0"
                  Background="White"
                  RowBackground="White"
                  AlternatingRowBackground="#FFFAFAFA"
                  RowHeight="40"
                  FontSize="14"
                  Margin="9,9,9,9"
                  ScrollViewer.VerticalScrollBarVisibility="Visible">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="FontSize" Value="15"/>
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                            <Setter Property="BorderBrush" Value="#FFDDDDDD"/>
                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="10,0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGrid.CellStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Horaire" Binding="{Binding Horaire}" Width="*"/>
                        <DataGridTextColumn Header="Cours" Binding="{Binding Cours.CoursNom}" Width="*"/>
                        <DataGridTextColumn Header="Salle" Binding="{Binding Salle.SalleNom}" Width="*"/>
                        <DataGridTextColumn Header="Entraîneur" Binding="{Binding Entraineur.EntraineurPrenom}" Width="*"/>
                        <DataGridTextColumn Header="Inscrit" Binding="{Binding NbPlaces}" Width="*"/>
                        <DataGridTemplateColumn Header="Statut" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button x:Name="butDetailCours" Content="Voir" Background="#FF4CAF50" Foreground="White" FontWeight="Bold" BorderThickness="0" Padding="15,5" Margin="5" Cursor="Hand" Click="butDetailCours_Click"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Border>
    </Grid>
</UserControl>
