<UserControl x:Class="SAE_2._01_Basic_Fit.Employe.UCWindow.pageParticipant"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SAE_2._01_Basic_Fit.Employe.UCWindow"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="#FFFF8C42">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Margin="50,20,50,0" Padding="10" CornerRadius="10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Nom" FontSize="13" FontWeight="Bold" Foreground="Black" VerticalAlignment="Center"/>
                <TextBox x:Name="filtreNom" Width="120" Height="22" Background="#FFD9D9D9" BorderBrush="#FFD9D9D9" FontSize="14" Margin="5,0,20,0" VerticalContentAlignment="Center" TextChanged="filtreNom_TextChanged"/>
                <TextBlock Text="Prenom" FontSize="13" FontWeight="Bold" Foreground="Black" VerticalAlignment="Center"/>
                <TextBox x:Name="filtrePrenom" Width="120" Height="22" Background="#FFD9D9D9" BorderBrush="#FFD9D9D9" FontSize="14" Margin="5,0,20,0" VerticalContentAlignment="Center" TextChanged="filtrePrenom_TextChanged"/>
                <TextBlock Text="Telephone" FontSize="13" FontWeight="Bold" Foreground="Black" VerticalAlignment="Center"/>
                <TextBox x:Name="filtreTel" Width="120" Height="22" Background="#FFD9D9D9" BorderBrush="#FFD9D9D9" FontSize="14" Margin="5,0,0,0" VerticalContentAlignment="Center" TextChanged="filtreTel_TextChanged"/>
            </StackPanel>
        </Border>
        
        <Border Grid.Row="1" BorderThickness="1" Margin="50,10,50,32" Background="White" CornerRadius="10">
            <DataGrid x:Name="dgClient"
                  ItemsSource="{Binding Client}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#FFEEEEEE"
                  BorderThickness="0"
                  Background="White"
                  RowBackground="White"
                  AlternatingRowBackground="#FFFAFAFA"
                  RowHeight="40"
                  FontSize="14"
                  Margin="9"
                  ScrollViewer.VerticalScrollBarVisibility="Auto">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="FontSize" Value="15"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="BorderThickness" Value="0,0,0,2"/>
                        <Setter Property="BorderBrush" Value="#FFDDDDDD"/>
                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="10,0"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="*"/>
                    <DataGridTextColumn Header="Prenom" Binding="{Binding Prenom}" Width="*"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Mail}" Width="*"/>
                    <DataGridTextColumn Header="Telephone" Binding="{Binding Telephone}" Width="*"/>
                    <DataGridTextColumn Header="Age" Binding="{Binding AgeAffiche}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
