<Window x:Class="SAE_2._01_Basic_Fit.Responsable.Window.popupAjouterCours"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SAE_2._01_Basic_Fit.Responsable.Window"
        mc:Ignorable="d"
        Title="popupAjouterCours" Height="500" Width="500">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="+ Ajouter un cours"
                   FontSize="20" FontWeight="Bold"
                   Margin="0,0,0,25"/>

        <StackPanel Grid.Row="1">

            
            <TextBlock Text="Nom du cours *" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtNomCours" Height="28" Padding="3"/>
            <TextBlock Text="Le nom doit être unique." FontSize="11" Foreground="Gray" Margin="0,3,0,15"/>

            <TextBlock Text="Catégorie *" FontWeight="Bold" Margin="0,0,0,5"/>
            <ComboBox x:Name="cbxCategorie" Height="28" DisplayMemberPath="CategorieNom"/>

            <TextBlock Text="Description *" FontWeight="Bold" Margin="0,15,0,5"/>
            <TextBox x:Name="txtDescription" Height="120" Padding="5"
                     TextWrapping="Wrap" AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"/>
        </StackPanel>
     
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,0">
            <Button x:Name="butAnnuler" Content="Annuler"
                    Width="110" Height="38"
                    Background="#FFE5E5E5" BorderBrush="#FFE5E5E5"
                    FontSize="14" Margin="0,0,10,0"
                    Click="butAnnuler_Click"/>
            <Button x:Name="butEnregistrer" Content="✓ Enregistrer"
                    Width="130" Height="38"
                    Background="#FF4CAF50" BorderBrush="#FF4CAF50" Foreground="White"
                    FontSize="14" FontWeight="Bold"
                    Click="butEnregistrer_Click"/>
        </StackPanel>
    </Grid>
</Window>
