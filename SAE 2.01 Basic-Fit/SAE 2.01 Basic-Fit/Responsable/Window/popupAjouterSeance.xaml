<Window x:Class="SAE_2._01_Basic_Fit.Responsable.Window.popupAjouterSeance"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SAE_2._01_Basic_Fit.Responsable.Window"
        mc:Ignorable="d"
        Title="popupAjouterSeance" Height="440" Width="600">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        
        <TextBlock Grid.Row="0" Text="+ Ajouter une séance"
                   FontSize="20" FontWeight="Bold"
                   Margin="0,0,0,25"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="15"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="15"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Cours *" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBlock Grid.Row="0" Grid.Column="2" Text="Entraîneur *" FontWeight="Bold" Margin="0,0,0,5"/>
            <ComboBox x:Name="cbxCours" Grid.Row="1" Grid.Column="0" Height="28"/>
            <ComboBox x:Name="cbxEntraineur" Grid.Row="1" Grid.Column="2" Height="28"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Jour *" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBlock Grid.Row="3" Grid.Column="2" Text="Heure début *" FontWeight="Bold" Margin="0,0,0,5"/>
            <ComboBox x:Name="cbxJour" Grid.Row="4" Grid.Column="0" Height="28">
                <ComboBoxItem Content="Lundi" IsSelected="True"/>
                <ComboBoxItem Content="Mardi"/>
                <ComboBoxItem Content="Mercredi"/>
                <ComboBoxItem Content="Jeudi"/>
                <ComboBoxItem Content="Vendredi"/>
                <ComboBoxItem Content="Samedi"/>
                <ComboBoxItem Content="Dimanche"/>
            </ComboBox>
            <TextBox x:Name="txtHeureDebut" Grid.Row="4" Grid.Column="2" Text="08:00" Height="28" Padding="3"/>
            <TextBlock Grid.Row="5" Grid.Column="2" Text="Le cours a une durée fixe de 1h."
                       FontSize="11" Foreground="Gray" Margin="0,3,0,0"/>

            <TextBlock Grid.Row="7" Grid.Column="0" Text="Salle *" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBlock Grid.Row="7" Grid.Column="2" Text="Nombre de places *" FontWeight="Bold" Margin="0,0,0,5"/>
            <ComboBox x:Name="cbxSalle" Grid.Row="8" Grid.Column="0" Height="28"/>
            <TextBox x:Name="txtNbPlaces" Grid.Row="8" Grid.Column="2" Text="20" Height="28" Padding="3"/>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,0">
            <Button x:Name="butAnnuler" Content="Annuler"
                    Width="110" Height="38"
                    Background="#FFE5E5E5" BorderBrush="#FFE5E5E5"
                    FontSize="14" Margin="0,0,10,0"
                    Click="butAnnuler_Click"/>
            <Button x:Name="butEnregistrer" Content="✓ Enregistrer"
                    Width="130" Height="38"
                    Background="#FF4CAF50" BorderBrush="#FF4CAF50" Foreground="White"
                    FontSize="14" FontWeight="Bold"
                    Click="butEnregistrer_Click"/>
        </StackPanel>
    </Grid>
</Window>
