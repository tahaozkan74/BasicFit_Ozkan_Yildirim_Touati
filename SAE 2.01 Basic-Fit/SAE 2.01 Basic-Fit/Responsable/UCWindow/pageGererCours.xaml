<UserControl x:Class="SAE_2._01_Basic_Fit.Responsable.UCWindow.pageGererCours"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SAE_2._01_Basic_Fit.Responsable.UCWindow"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="#FFFF8C42">
        <Border BorderThickness="1" Margin="50,34,50,10" Background="White" CornerRadius="10,10,10,10">
            <Grid Margin="9">

                <Button x:Name="butNouveauCours" Content="+ Nouveau cours" HorizontalAlignment="Right" VerticalAlignment="Top" Background="#FF27AE60" Foreground="White" FontWeight="Bold" Padding="15,8" Cursor="Hand" Margin="0,0,5,0" Click="butNouveauCours_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <DataGrid x:Name="dgCours"
                  ItemsSource="{Binding Seance}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#FFEEEEEE"
                  BorderThickness="0"
                  Background="White"
                  RowBackground="White"
                  AlternatingRowBackground="#FFFAFAFA"
                  RowHeight="40"
                  FontSize="14"
                  Margin="0,45,0,0"
                  ScrollViewer.VerticalScrollBarVisibility="Auto">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="FontSize" Value="15"/>
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                            <Setter Property="BorderBrush" Value="#FFDDDDDD"/>
                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="10,0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGrid.CellStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nom" Binding="{Binding CoursNom}" Width="*"/>
                        <DataGridTextColumn Header="Categorie" Binding="{Binding Categorie.CategorieNom}" Width="*"/>
                        <DataGridTextColumn Header="Description" Binding="{Binding CoursDescription}" Width="2*"/>
                        <DataGridTextColumn Header="Seances" Binding="{Binding NbSeances}" Width="*"/>
                        <DataGridTemplateColumn Header="Action" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Modifier" Background="#FFF37F08" Foreground="White" FontWeight="Bold" BorderThickness="0" Padding="15,5" Margin="5" Cursor="Hand" Click="butModifier_Click"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Supprimer" Background="#FFED0E0E" Foreground="White" FontWeight="Bold" BorderThickness="0" Padding="15,5" Margin="5" Cursor="Hand"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

            </Grid>
        </Border>
    </Grid>
</UserControl>
