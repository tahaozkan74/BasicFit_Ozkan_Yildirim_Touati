<UserControl x:Class="SAE_2._01_Basic_Fit.Responsable.UCWindow.pagePrincipal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SAE_2._01_Basic_Fit.Responsable.UCWindow"
             mc:Ignorable="d" 
             d:DesignHeight="750" d:DesignWidth="1250">
    <Grid Background="#FFFF8C42">
        <StackPanel>
            <Border BorderThickness="1" Height="172" Margin="-1,-1,-1,0" Background="White" >

                <StackPanel Orientation="Horizontal" Margin="0,0,0,-1">
                    <Image Source="/Image/basic-fit-logo.png" Height="99" Width="302" Margin="23,-15,0,40" />
                    <TextBlock Text="ESPACE RESPONSABLE" FontSize="40" FontWeight="Bold" Foreground="Black" Width="429" Height="70" Margin="108,-15,0,40"/>
                    <Border BorderThickness="1" Height="52" Width="221" Background="#FFA7A6A6" CornerRadius="20,20,20,20" Margin="56,-15,0,40"/>
                    <Button Width="50" Height="50" Margin="20,-15,0,40" Background="White" BorderBrush="White">
                        <Image Source="/Image/logout.png" Height="45" Width="97" RenderTransformOrigin="0.5,0.5" Margin="-17,0,0,0">
                            <Image.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform/>
                                    <SkewTransform AngleY="-0.39"/>
                                    <RotateTransform/>
                                    <TranslateTransform Y="-0.16"/>
                                </TransformGroup>
                            </Image.RenderTransform>
                        </Image>
                    </Button>
                    <Button x:Name="butGererCours" Content="📚 Gérer les cours" FontSize="30" FontWeight="Bold" Foreground="Black" Width="269" Height="56" Margin="-2096,110,0,0" Background="White" BorderBrush="White" Click="butGererCours_Click" />
                    <Button x:Name="butGererSeance" Content="📅 Gérer les séances" FontSize="30" FontWeight="Bold" Foreground="Black" Width="292" Height="56" Margin="-1504,110,0,0" BorderBrush="White" Background="White" Click="butGererSeance_Click" />
                    <Button x:Name="butCategorie" Content="🗂️ Catégories" FontSize="30" FontWeight="Bold" Foreground="Black" Width="214" Height="56" Margin="-950,110,0,0" BorderBrush="White" Background="White" Click="butCategorie_Click" />
                </StackPanel>
            </Border>

        </StackPanel>

        <ScrollViewer Margin="0,170,0,0">
            <ContentControl x:Name="ZoneContenu" Margin="0,18,0,0" Height="525" Width="1230"/>
        </ScrollViewer>
    </Grid>
</UserControl>
